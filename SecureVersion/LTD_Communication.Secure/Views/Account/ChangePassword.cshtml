@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-success">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-key-fill"></i> Change Password <small class="fs-6 ms-2">[SECURE]</small></h4>
            </div>
            <div class="card-body">
                <div class="alert alert-success py-2">
                    <strong><i class="bi bi-shield-check"></i> Protections:</strong>
                    <ul class="mb-0">
                        <li>Full password policy enforced (length, complexity, dictionary)</li>
                        <li>Last 3 passwords checked — no reuse allowed</li>
                        <li>New password stored as PBKDF2 hash with new unique salt</li>
                    </ul>
                </div>

                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-semibold">Current Password</label>
                        <input asp-for="CurrentPassword" class="form-control" type="password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                        <input asp-for="NewPassword" class="form-control" type="password" />
                        <small class="text-muted">Must meet all policy requirements and differ from last 3 passwords.</small>
                        <span asp-validation-for="NewPassword" class="text-danger small d-block"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm New Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold">
                        <i class="bi bi-check-circle"></i> Change Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
