@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-success">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-lock-fill"></i> Reset Password <small class="fs-6 ms-2">[SECURE]</small></h4>
            </div>
            <div class="card-body">
                <div class="alert alert-success py-2">
                    <strong><i class="bi bi-shield-check"></i> Protection:</strong>
                    Submitted token is SHA-1 hashed before DB lookup — plain token never compared directly.
                    Full password policy applied to new password.
                </div>

                <form asp-action="ResetPassword" method="post">
                    <input asp-for="Token" type="hidden" />
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                        <input asp-for="NewPassword" class="form-control" type="password" />
                        <small class="text-muted">Must meet all policy requirements.</small>
                        <span asp-validation-for="NewPassword" class="text-danger small d-block"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm New Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold">
                        <i class="bi bi-check-circle"></i> Reset Password
                    </button>
                </form>
            </div>
            <div class="card-footer text-center bg-light">
                <a asp-action="Login">Back to Login</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
