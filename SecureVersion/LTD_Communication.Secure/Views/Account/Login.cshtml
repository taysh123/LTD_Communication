@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow border-success">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-shield-lock-fill"></i> Login <small class="fs-6 ms-2">[SECURE]</small></h4>
            </div>
            <div class="card-body">
                <div class="alert alert-success py-2">
                    <strong><i class="bi bi-shield-check"></i> Protection:</strong>
                    Username fetched via <code>WHERE Username = @@Username</code> (parameterized).
                    Password verified using PBKDF2 — SQL Injection attempts are harmless here.
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold">Username</label>
                        <input asp-for="Username" class="form-control" autocomplete="off" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Password</label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </button>
                </form>
            </div>
            <div class="card-footer text-center bg-light">
                <a asp-action="ForgotPassword" class="text-decoration-none me-3">Forgot Password?</a>
                <a asp-action="Register" class="text-decoration-none">Register</a>
            </div>
        </div>

        <div class="card mt-3 border-secondary">
            <div class="card-header bg-secondary text-white py-2">
                <small><strong>Default Credentials (auto-seeded)</strong></small>
            </div>
            <div class="card-body py-2">
                <small>Username: <strong>admin</strong> &nbsp;|&nbsp; Password: <strong>Admin@12345!</strong></small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
