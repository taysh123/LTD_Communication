@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-success">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="bi bi-envelope-check-fill"></i> Forgot Password <small class="fs-6 ms-2">[SECURE]</small></h4>
            </div>
            <div class="card-body">
                <div class="alert alert-success py-2">
                    <strong><i class="bi bi-shield-check"></i> Protection:</strong>
                    Token hashed with SHA-1 before storage. Only the hash is in the database —
                    the raw token travels in the reset URL. Parameterized query prevents SQL Injection.
                    Identical response whether email exists or not (prevents user enumeration).
                </div>

                @if (TempData["ResetLink"] != null)
                {
                    <div class="alert alert-info">
                        <strong><i class="bi bi-envelope-check"></i> Simulated Email — Reset Link:</strong><br />
                        <small><a href="@TempData["ResetLink"]" class="text-break">@TempData["ResetLink"]</a></small>
                        <hr class="my-2" />
                        <small class="text-muted">In production this would be sent by email only. The DB stores only the SHA-1 hash of this token.</small>
                    </div>
                }

                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="Enter your registered email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold">
                        <i class="bi bi-send"></i> Send Reset Link
                    </button>
                </form>
            </div>
            <div class="card-footer text-center bg-light">
                <a asp-action="Login">Back to Login</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
