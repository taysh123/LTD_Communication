@model List<Customer>
@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>
        Customers
        <span class="badge bg-danger fs-6 ms-2">Stored XSS Vulnerable</span>
    </h2>
    <a asp-action="Add" class="btn btn-danger">
        <i class="bi bi-plus-circle"></i> Add Customer
    </a>
</div>

<div class="alert alert-danger border-2 py-2">
    <strong><i class="bi bi-exclamation-triangle-fill"></i> Active Stored XSS:</strong>
    The <strong>Name</strong> column uses <code>@@Html.Raw()</code> — any <code>&lt;script&gt;</code> tag stored in the database
    will execute here as JavaScript.
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No customers yet. <a asp-action="Add">Add the first customer</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover bg-white shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Name <span class="badge bg-danger">@@Html.Raw() — XSS</span></th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Sector</th>
                    <th>Package</th>
                    <th>Added</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Id</td>
                        @* VULNERABLE: @Html.Raw renders stored script tags unescaped *@
                        <td>@Html.Raw(c.FullName)</td>
                        <td>@Html.Raw(c.Email)</td>
                        <td>@c.Phone</td>
                        <td>@c.SectorName</td>
                        <td>@c.PackageName</td>
                        <td>@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
