@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-person-plus-fill"></i> Register <small class="fs-6 ms-2">[VULNERABLE]</small></h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning py-2">
                    <strong>Vulnerabilities:</strong> No password policy enforced. SQL Injection possible in Username/Email. Password stored as plain text.
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold">Username</label>
                        <input asp-for="Username" class="form-control" autocomplete="off" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Password</label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <small class="text-muted">No policy — any password accepted (e.g. "abc")</small>
                        <span asp-validation-for="Password" class="text-danger small d-block"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-danger w-100 fw-bold">
                        <i class="bi bi-person-check"></i> Register
                    </button>
                </form>
            </div>
            <div class="card-footer text-center bg-light">
                Already have an account? <a asp-action="Login">Login</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
